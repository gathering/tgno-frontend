---
import H1 from "../../components/H1.astro";
import Intro from "../../components/Intro.astro";
import Main from "../../components/Main.astro";
import ContentContainer from "../../components/ContentContainer.astro";
import Layout from "../../layouts/Layout.astro";
import BodyText from "../../components/BodyText.astro";
import { noLocalizeContributor } from "../../utils";
import type { Contributor } from "../../types";

type ImageSize = { url: string; width: number; height: number };
type PreviewArticle = {
  id: number;
  title: string;
  intro: string;
  body: string;
  tags: { id: number; name: string; slug: string }[];
  contributors: Contributor[];
  main_image: null | {
    id: number;
    title: string;
    alt: string;
    sizes: Record<string, ImageSize>;
    uncroppable?: boolean;
  };
  meta: {
    first_published_at: string | null;
    custom_published_at: string | null;
    seo_title: string;
    search_description: string;
    locale: "no" | "en" | null;
  };
};

const token = Astro.url.searchParams.get("token");
if (!token) {
  return new Response("Missing preview token.", { status: 400 });
}

const apiUrl = import.meta.env.API_URL;
const res = await fetch(
  `${apiUrl}api/v2/preview/news/${encodeURIComponent(token)}/`,
  {
    headers: { Accept: "application/json" },
  },
);

if (!res.ok) {
  return new Response("Preview not found", { status: res.status });
}

const article = (await res.json()) as PreviewArticle;

const datePublished = article?.meta?.custom_published_at
  ? article.meta.custom_published_at
  : article?.meta?.first_published_at;
---

<Layout
  title=`Preview - ${article.title}`
  description=`${article.meta?.search_description ?? ""}`
  seo_title=`${article.meta?.seo_title ?? ""}`
  search_description=`${article.meta?.search_description ?? ""}`
  introText=`${article.intro ?? ""}`
  type="article"
  lang={(article.meta?.locale || "no") as "no" | "en"}
  image=`${article.main_image?.sizes?.large?.url}`
>
  <Main>
    <ContentContainer
      variant={article.main_image?.uncroppable ? "narrow" : "wide"}
    >
      <H1 text={article.title} />
      {
        article.main_image && (
          <div class="flex md:max-h-[50vh] md:min-h-[600px]">
            <img
              src={article.main_image.sizes.large.url}
              srcset={(Object.values(article.main_image.sizes) as ImageSize[])
                .sort((a: ImageSize, b: ImageSize) => a.width - b.width)
                .map((size: ImageSize) => `${size.url} ${size.width}w`)
                .join(", ")}
              alt={article.main_image.alt}
              class="w-full rounded-3xl md:object-cover object-center"
            />
          </div>
        )
      }
    </ContentContainer>
    <ContentContainer variant="narrow">
      <Intro text={article.intro} />
      <BodyText class="mb-6" htmlBody={article.body} />
      <aside
        class="my-6 p-5 space-y-5 clear-both text-sm text-white/60 bg-background-secondary rounded"
      >
        <section class="space-y-1">
          <time
            datetime={article.meta?.first_published_at}
            class="text-sm text-white/90"
          >
            Publisert:{" "}
            {
              datePublished
                ? new Date(datePublished).toLocaleDateString("nb-NO", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })
                : ""
            }
          </time>
          {
            !!article.tags?.length ? (
              <p class="text-sm mb-1">
                {article.tags
                  .map((tag: PreviewArticle["tags"][number]) =>
                    tag.name
                      .split(" ")
                      .map(
                        (word: string) =>
                          word.charAt(0).toUpperCase() + word.slice(1),
                      )
                      .join(" "),
                  )
                  .join(", ")}
              </p>
            ) : null
          }
        </section>
        {
          !!article.contributors?.length ? (
            <section>
              <div class="flex flex-row flex-wrap text-sm -mb-2">
                {article.contributors
                  .map(noLocalizeContributor)
                  .map(
                    (contributor: PreviewArticle["contributors"][number]) => (
                      <dl class="flex flex-col mb-2 mr-4">
                        <dt class="font-bold text-white/90">
                          {contributor.name}
                        </dt>
                        <dd class="">{contributor.contribution_type}</dd>
                      </dl>
                    ),
                  )}
              </div>
            </section>
          ) : null
        }
      </aside>
    </ContentContainer>
  </Main>
</Layout>
