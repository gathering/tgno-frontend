---
import Main from "../../../components/Main.astro";
import ContentContainer from "../../../components/ContentContainer.astro";
import Layout from "../../../layouts/Layout.astro";
import { fetchCompetitionPageBySlug } from "../../../utils";
import CompetitionBox from "../../../components/competitions/creative/CompetitionBox.astro";
import CreativeBox from "../../../components/competitions/creative/CreativeBox.astro";
import { API_URL } from "../../../utils/runtime-env";

const sectionPrefix = "/creative/";

const { slug = "" } = Astro.params;

const path = new URL(slug, "http://example.com").pathname;

if (typeof path !== "string") {
  return Astro.rewrite("/404");
}

const competition = await fetchCompetitionPageBySlug({
  path: path.startsWith(sectionPrefix) ? path : `/creative${path}`,
  api_url: API_URL,
});

if (!competition) {
  return Astro.rewrite("/404");
}
---

<Layout
  title=`The Gathering - ${competition.title} konkurranse`
  description=`${competition.description || competition.title}`
  search_description=`${competition.description || competition.title}`
>
  <Main>
    <ContentContainer variant="wide">
      <a
        href="/competitions/creative"
        class="flex text-sm text-gray-500 hover:text-gray-700 mb-4"
        target="_blank"
      >
        &larr; Tilbake til oversikten
      </a>
      <div class="grid grid-cols-1 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        <CompetitionBox {...competition} action={false} class="sm:order-last" />
        <CreativeBox class="sm:row-span-2 sm:col-span-2 lg:col-span-3">
          <span class="prose prose-invert">
            <h2 class="mt-0 mb-6 text-4xl font-bold">
              Rules for {competition.title}
            </h2>
            {
              competition.rule_sets.map((ruleSet) => (
                <>
                  <h3>{ruleSet.title}</h3>
                  <div set:html={ruleSet.rules} />
                </>
              ))
            }
          </span>
        </CreativeBox>
      </div>
    </ContentContainer>
  </Main>
</Layout>
