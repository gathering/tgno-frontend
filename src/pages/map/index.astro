  },
  {
    ...FOOD.placeholder,
    ...getStandSize("8x4"),
    pos: { x: units(32), y: units(51.5) },
  },
  ...calculateColumn(
    [
      {
        ...FOOD.placeholder,
        ...getStandSize("3x6"),
        pos: { x: units(42), y: units(56) },
      },
      {
        ...FOOD.placeholder,
        ...getStandSize("3x6"),
      },
    ],
    "up",
  ),
  // Stages
  {
    ...STAGES.mainStage,
    width: 280,
    height: 250,
    pos: { x: 1300, y: 1310 },
  },
  {
    ...STAGES.eSportStage,
    width: 280,
    height: 190,
    pos: { x: 1300, y: 1600 },
  },
  // Toilets and showers
  // toilets - top
  {
    ...ATTRACTIONS.toilet,
    ...getStandSize("10x6"),
    pos: { x: 1400, y: 1941 },
  },
  {
    ...ATTRACTIONS.toilet,
    ...getStandSize("10x6"),
    pos: { x: 1830, y: 1941 },
  },
  // toilets - right
  {
    ...ATTRACTIONS.toilet,
    ...getStandSize("6x10"),
    pos: { x: 3200, y: 1344 },
  },
  {
    ...ATTRACTIONS.toilet,
    ...getStandSize("6x10"),
    pos: { x: 3200, y: 1030 },
  },
  // toilets - left
  {
    ...ATTRACTIONS.toilet,
    ...getStandSize("6x10"),
    pos: { x: 60, y: 1344 },
  },
  {
    ...ATTRACTIONS.toilet,
    ...getStandSize("6x10"),
    pos: { x: 60, y: 1030 },
  },
  // toilets and showers - bottom
  {
    ...ATTRACTIONS.toilet,
    ...getStandSize("6x6"),
    pos: { x: 2156, y: 450 },
    presentation: {
      ...ATTRACTIONS.toilet.presentation,
      stickyLabel: false,
    },
