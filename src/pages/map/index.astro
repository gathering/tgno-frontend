const SIZES = {
  small: getStandSize("3x3"),
  medium: getStandSize("6x6"),
  long: getStandSize("6x3"),
  longVertical: getStandSize("3x6"),
  superlongVertical: getStandSize("3x9"),
} as const satisfies Record<string, { width: number; height: number }>;

const LOCATIONS: MapItem[] = [
  {
    ...STANDS.placeholder,
    ...getStandSize("46x38"),
    pos: { x: units(16), y: units(70) },
  },
  {
    ...STANDS.placeholder,
    ...getStandSize("20x30"),
    pos: { x: units(59), y: units(47) },
  },

  // Streamer cluster
  ...calculateColumn([
    {
      ...ATTRACTIONS.streamerLounge,
      ...getStandSize("10x10"),
      pos: { x: units(50.5), y: units(105) },
    },
    {
      ...ATTRACTIONS.streamers,
      ...getStandSize("10x3"),
    },
  ]),
  // TG Shop cluster, lower left above reception
  ...calculateColumn(
    [
      {
        ...ATTRACTIONS.tgShop,
        ...getStandSize("12x12"),
        pos: { x: units(45), y: units(46) },
      },
      {
        ...ATTRACTIONS.support,
        ...getStandSize("5x5"),
        presentation: {
          ...ATTRACTIONS.support.presentation,
          labelWidth: 7,
