    icon: "https://www.tg.no/tg25/tg25_icon_white.svg",
    name: "Esportscenen",
    presentation: {
      type: "stage",
      showInNavigation: true,
      showPopup: true,
      mapIcon: true,
      calendarQuery: ["esportscenen"],
      padding: 40,
    },
  },
  creativiaStage: {
    icon: "https://www.tg.no/tg25/tg25_icon_white.svg",
    name: "Kreativiascenen",
    presentation: {
      type: "stage",
      showInNavigation: true,
      showPopup: true,
      mapIcon: true,
      calendarQuery: ["kreativiascenen"],
      padding: 40,
