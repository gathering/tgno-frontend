    ],
    "right",
    units(3),
  ),
  ...calculateRow(
    [
      {
        ...ATTRACTIONS.sektor,
        name: "Sektor",
        ...getStandSize("25x30"),
        pos: { x: units(82), y: units(47) },
      },
      {
        ...ATTRACTIONS.sektor,
        name: "Sektor",
        ...getStandSize("29x30"),
      },
      {
        ...ATTRACTIONS.sleepingArea,
        name: "Sektor",
        ...getStandSize("10x30"),
