---
import "leaflet/dist/leaflet.css";
import {
  units,
  calculateRow,
  calculateColumn,
  getStandSize,
  stringToSize,
  rotateCords,
  getStandPolygon,
  slugifyMapItemName,
} from "../../utils/map";
import TgMap from "../../components/map/TgMap.astro";
import type { MapItem, PartialMapItem } from "../../types";
import Layout from "../../layouts/Layout.astro";
import TgMapNavItem from "../../components/map/TgMapNavItem.astro";
import H3 from "../../components/H3.astro";

type MapItemBase = Pick<PartialMapItem, "name"> &
  Partial<Omit<PartialMapItem, "name">>;

type LocationMap = Record<string, MapItemBase>;

const TYPE_COLORS = {
  attraction: "purple",
  hygiene: "green",
  food: "red",
  stand: "blue",
  stage: "orange",
  unknown: "gray",
  placeholder: "gray",
};

const STANDS = {
  placeholder: {
    name: "Placeholder",
    presentation: {
      type: "placeholder",
    },
  },
} as const satisfies LocationMap;

const FOOD = {
  placeholder: {
    name: "Placeholder",
    presentation: {
      type: "placeholder",
    },
  },
} as const satisfies LocationMap;

const ATTRACTIONS = {
