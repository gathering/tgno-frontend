  {
    ...ATTRACTIONS.showers,
    ...getStandSize("60x6"),
    pos: { x: 1150, y: 490 },
  },
  // Security and medic
  {
    ...ATTRACTIONS.security,
    ...getStandSize("10x6"),
    pos: { x: 2306, y: 550 },
  },
  {
    ...ATTRACTIONS.medic,
    ...getStandSize("10x6"),
    pos: { x: 883, y: 500 },
  },
  // Seating and sleeping sectors
  ...calculateRow(
    [
      {
        ...ATTRACTIONS.sektor,
        name: "Sektor",
        ...getStandSize("29x30"),
        pos: { x: units(110), y: units(82) },
      },
      {
        ...ATTRACTIONS.sektor,
        name: "Sektor",
        ...getStandSize("10x20"),
