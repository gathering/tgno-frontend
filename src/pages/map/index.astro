  },
  chillout: {
    name: "Lounge",
    icon: "https://www.tg.no/tg25/tg25_icon_white.svg",
    presentation: {
      type: "stage",
      showInNavigation: true,
      showPopup: true,
      mapIcon: true,
      calendarQuery: ["lounge"],
      padding: 40,
    },
  },
  tgHack: {
    name: "TG:Hack",
    presentation: {
