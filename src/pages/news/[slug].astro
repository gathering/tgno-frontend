---
import { fetchArticleIdBySlug, fetchArticleById } from "../../utils";
import ArticlePage from "../../components/news/ArticlePage.astro";
import type { Article } from "../../types";

const { slug } = Astro.params;
const token = Astro.url.searchParams.get("token");

if (!slug) {
  return Astro.rewrite("/404");
}

let article: Article;
if (token) {
  const apiUrl = import.meta.env.API_URL;
  const res = await fetch(
    `${apiUrl}api/v2/preview/news/${encodeURIComponent(token)}/`,
    { headers: { Accept: "application/json" } },
  );
  if (!res.ok) {
    return new Response("Preview not found", { status: res.status });
  }
  article = (await res.json()) as Article;
} else {
  const id = await fetchArticleIdBySlug({
    slug,
    api_url: import.meta.env.API_URL,
  });

  if (!id) {
    return Astro.rewrite("/404");
  }

  article = await fetchArticleById({
    id,
    api_url: import.meta.env.API_URL,
  });
}
---

<ArticlePage
  article={article}
  pageTitlePrefix={token ? "Preview -" : "The Gathering -"}
  includeJsonLd={!token}
/>
