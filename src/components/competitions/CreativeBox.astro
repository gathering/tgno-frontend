---
import H2 from "../../components/H2.astro";
import Button from "../Button.astro";
import type { Competition, CreativeCategory } from "../../utils";

export interface Props extends Pick<
  Competition,
  "name" | "description" | "category" | "prizes"
> {
  children: any;
  slug?: Competition["slug"];
  class?: string;
}

const { name, prizes = [], class: classNames, category } = Astro.props;

const url = Astro.props.slug
  ? `/competitions/creative/${Astro.props.slug}`
  : null;

const formatPrice = (prize: number | string) =>
  typeof prize === "string"
    ? prize
    : new Intl.NumberFormat("nb-NO", {
        style: "currency",
        currency: "NOK",
        maximumFractionDigits: 0,
      }).format(prize);

const categoryStyles: Record<CreativeCategory, string> = {
  photo: "bg-red-500",
  video: "bg-green-500",
  graphics: "bg-sky-500",
  music: "bg-yellow-500",
  misc: "bg-purple-500",
  physical: "bg-indigo-500",
  programming: "bg-pink-500",
};

const categoryStyle = categoryStyles[category || "misc"];
const hasPrices = !!prizes.length;
const prizeGroups = prizes.every(Array.isArray) ? prizes : [prizes];
---

<section class={`flex flex-col gap-4 ${categoryStyle} ${classNames}`}>
  <H2 text={name} color="" />
  <span>
    <slot />
  </span>
  {
    hasPrices
      ? prizeGroups.map((groupPrizes) => (
          <>
            <dl class="divide-y divide-black/50 mt-5 last:pt-5 last:mt-auto">
              {groupPrizes.map(({ name, price }, index) => (
                <div class="px-2 py-1 grid grid-cols-3 sm:gap-2 sm:px-0">
                  <dt class="text-sm font-bold leading-4 text-black/90 col-span-2 sm:col-span-1">
                    {name || `${index + 1}. plass`}
                  </dt>
                  <dd class="mt-1 text-sm leading-4 text-black/70 sm:col-span-2 sm:mt-0">
                    {price ? formatPrice(price) : "TBA"}
                  </dd>
                </div>
              ))}
            </dl>
          </>
        ))
      : null
  }
  {
    url && (
      <Button href={url} variant="wide" theme="transparent" class="mt-auto">
        Les mer
      </Button>
    )
  }
</section>
